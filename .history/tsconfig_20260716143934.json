{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"] // <-- Указывает TypeScript автоматически подгрузить типы Node.js глобально
  },
  // Указываем компилятору смотреть только на файлы внутри папки src
  "include": ["src/**/*"],
  // И полностью игнорировать огромную папку node_modules
  "exclude": ["node_modules"]
}
