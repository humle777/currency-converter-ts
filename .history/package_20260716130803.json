{
  "name": "conventer", // Имя нашего проекта. Кстати, тут небольшая опечатка: пропущена буква "e" (правильно: converter), но это легко поправим!
  "version": "1.0.0", // Текущая версия твоего приложения.
  "type": "module", // Говорит Node.js, что мы используем современный формат ESM-модулей (ключевые слова import/export).
  "main": "index.js", // Главный файл-точка входа по умолчанию (мы его перекрываем своими скриптами).
  
  "scripts": {
    // Наш встроенный скрипт для запуска тестов (пока заглушка, которая выдает ошибку)
    "test": "echo \"Error: no test specified\" && exit 1", 
    // Наша любимая команда! Теперь при вводе "npm run convert" запускается современный компилятор tsx для файла src/index.ts
    "convert": "tsx src/index.ts" 
  },
  
  "keywords": [], // Ключевые слова для поиска проекта (если бы мы публиковали его в общий доступ).
  "author": "", // Твое имя как создателя.
  "license": "ISC", // Лицензия открытого ПО.
  
  "devDependencies": {
    // devDependencies — это "инструменты для разработки". Они нужны нам, разработчикам и QA, на этапе написания кода и тестов, но не нужны обычному пользователю.
    "@types/inquirer": "^9.0.10", // Подсказки типов TypeScript для inquirer, чтобы VS Code не ругался на типы данных.
    "@types/node": "^26.1.1", // Подсказки типов для самой среды Node.js.
    "tsx": "^4.23.1" // Супер-быстрый инструмент, который на лету переводит TypeScript в понятный для Node.js код и запускает его.
  },
  
  "dependencies": {
    // dependencies — это "ингредиенты самого приложения". Без этих библиотек программа не запустится у конечного пользователя.
    "inquirer": "^14.0.2" // Наша библиотека для красивых интерактивных меню в консоли!
  }
}
